{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "estandarizacion": {
            "projectType": "application",
            "schematics": {},
            "root": "",
            "sourceRoot": "frontend/src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "allowedCommonJsDependencies": [
                            "sweetalert2",
                            "html2canvas",
                            "jquery",
                            "backbone",
                            "raf",
                            "rgbcolor",
                            "core-js",
                            "canvg"
                        ],
                        "outputPath": "dist/estandarizacion",
                        "index": "./frontend/src/index.html",
                        "browser": "./frontend/src/main.ts",
                        "polyfills": [
                            "zone.js"
                        ],
                        "tsConfig": "./tsconfig.app.json",
                        "assets": [
                            "./frontend/src/assets",
                            "./frontend/src/favicon.ico"
                        ],
                        "styles": [
                            "@angular/material/prebuilt-themes/azure-blue.css",
                            "./frontend/src/input.css",
                            "./frontend/src/output.css",
                            "./frontend/src/styles.css"
                        ],
                        "scripts": []
                    },
                    "configurations": {
                        "production": {
                            "optimization": {
                                "scripts": true,
                                "styles": {
                                    "minify": true,
                                    "inlineCritical": false
                                },
                                "fonts": true
                            },
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "1MB",
                                    "maximumError": "2MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "4kB",
                                    "maximumError": "8kB"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "fileReplacements": [
                                {
                                    "replace": "frontend/src/environments/environment.ts",
                                    "with": "frontend/src/environments/environment.development.ts"
                                }
                            ],
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "estandarizacion:build:production"
                        },
                        "development": {
                            "buildTarget": "estandarizacion:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": [
                            "zone.js",
                            "zone.js/testing"
                        ],
                        "tsConfig": "tsconfig.spec.json",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            }
                        ],
                        "styles": [
                            "@angular/material/prebuilt-themes/azure-blue.css",
                            "node_modules/@coreui/coreui/dist/css/coreui.min.css",
                            "frontend/src/input.css",
                            "frontend/src/output.css",
                            "frontend/src/styles.css"
                        ],
                        "scripts": []
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": false
    }
}